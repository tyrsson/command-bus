{
    "ignore_php_platform_requirements": {
        "8.5": true
    },
    "additional_checks": [
        {
            "name": "PhpStan",
            "job": {
                "php": "8.2",
                "dependencies": "latest",
                "command": "composer require --dev --ignore-platform-reqs phpstan/phpstan && vendor/bin/phpstan analyse"
            }
        }
    ]
}