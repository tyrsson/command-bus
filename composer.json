{
    "name": "webware/command-bus",
    "description": "CommandBus for Mezzio",
    "license": "BSD-3-Clause",
    "keywords": [
        "webware",
        "CommandBus",
        "Mezzio"
    ],
    "homepage": "https://github.com/tyrsson/command-bus/discussions",
    "support": {
        "issues": "https://github.com/tyrsson/command-bus/issues",
        "source": "https://github.com/tyrsson/command-bus",
        "forum": "https://github.com/tyrsson/command-bus/discussions"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.99"
        },
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "laminas/laminas-component-installer": true
        }
    },
    "extra": {
        "laminas": {
            "config-provider": "Webware\\CommandBus\\ConfigProvider"
        }
    },
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "beberlei/assert": "^3.3",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "laminas/laminas-coding-standard": "^3.0.1",
        "laminas/laminas-servicemanager": "^4.0.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.5.42"
    },
    "suggest": {
        "laminas/laminas-servicemanager": "Laminas\\ServiceManager component"
    },
    "autoload": {
        "psr-4": {
            "Webware\\CommandBus\\": "src/"
        },
        "files": [
            "src/functions/priority_queue_reducer_factory.php",
            "src/functions/collection_mapper_factory.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Webware\\CommandBusTest\\": "test/unit/",
            "Webware\\CommandBusIntegrationTest\\": "test/integration/"
        }
    },
    "scripts": {
        "check": [
            "@cs-check",
            "@sa",
            "@test",
            "@test-integration"
        ],
        "cs-check": "phpcs",
        "cs-fix": "phpcbf",
        "test": "phpunit --colors=always --testsuite \"unit test\"",
        "test-coverage": "phpunit --colors=always --coverage-clover clover.xml",
        "test-integration": "phpunit --colors=always --testsuite \"integration test\"",
        "sa": "vendor/bin/phpstan analyse --memory-limit=256M",
        "sa-gen-baseline": "vendor/bin/phpstan analyse --memory-limit=256M --generate-baseline",
        "sa-verbose": "vendor/bin/phpstan analyse --memory-limit=256M -vv",
        "upload-coverage": "coveralls -v"
    }
}
